---
import type { HTMLAttributes } from 'astro/types';

import { Image } from 'astro:assets';

import SocialLink from '@/components/social-link.astro';
import {
  BentoCard,
  BentoCardContent,
  BentoCardDescription,
  BentoCardFooter,
  BentoCardImage,
  BentoCardTitle,
} from '@/components/ui/bento-card';
import { profile } from '@/data/profile';

interface Props extends Pick<HTMLAttributes<'div'>, 'class'> {}

const { class: className } = Astro.props;
const { name: profileName, summary } = profile;
---

<BentoCard class:list={['items-center', className]}>
  <BentoCardContent>
    <BentoCardTitle>{profileName}</BentoCardTitle>
    <BentoCardDescription class='text-lg leading-tight'>{summary}</BentoCardDescription>
  </BentoCardContent>
  <BentoCardImage class='size-60'>
    <Image src='/profile.webp' alt={profileName} width={500} height={519} priority />
  </BentoCardImage>
  <BentoCardFooter>
    <SocialLink name='GitHub' href='https://github.com/javalce' icon='github' />
    <SocialLink
      name='LinkedIn'
      href='https://www.linkedin.com/in/javier-valero-cejudo/'
      icon='linkedin'
    />
    <SocialLink name='NPM' href='https://www.npmjs.com/~javalce' icon='npm' />
    <SocialLink name='Email' href='mailto:javalce29@gmail.com' icon='mail' />
    <SocialLink name='Download CV' href='/CV_Javier_Valero_Cejudo.pdf' icon='download' />
  </BentoCardFooter>
</BentoCard>
