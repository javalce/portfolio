---
import type { HTMLAttributes } from 'astro/types';

import { tv } from 'tailwind-variants';

type Props = HTMLAttributes<'div'>;

const bentoCardFooter = tv({
  base: 'flex basis-full items-center gap-2',
});

const { class: className, ...rest } = Astro.props;
---

<div class={bentoCardFooter({ class: className })} data-slot='bento-card-footer' {...rest}>
  <slot />
</div>
